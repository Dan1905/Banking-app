# Copy this file to .env locally and fill in real values.
# Do not commit .env with secrets.

# Shared secrets
JWT_SECRET=change-me-to-a-long-random-secret
INTERNAL_API_TOKEN=change-me-to-a-random-internal-token

# Database URLs
# Use port 3307 when connecting to the MySQL container started by docker compose.
AUTH_DB_URL=jdbc:mysql://localhost:3307/auth_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
ACCOUNT_DB_URL=jdbc:mysql://localhost:3307/account_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
TRANSACTION_DB_URL=jdbc:mysql://localhost:3307/transaction_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true

# Database credentials
DB_USERNAME=root
DB_PASSWORD=root

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTION_EVENTS=transaction.events

# Service URLs
AUTH_SERVICE_URL=http://localhost:8081
ACCOUNT_SERVICE_URL=http://localhost:8082
TRANSACTION_SERVICE_URL=http://localhost:8083
NOTIFICATION_SERVICE_URL=http://localhost:8084
